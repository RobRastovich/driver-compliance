generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String
  dateOfBirth   DateTime
  address       String
  city          String
  state         String
  zip           String
  country          String   @default("US")
  cdlNumber        String?
  cdlIssuingState  String?
  profilePhotoKey  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents          Document[]
  verifications      Verification?
  readingRecordings  ReadingRecording[]

  @@map("drivers")
}

model ReadingRecording {
  id           String   @id @default(cuid())
  driverId     String
  sentenceIdx  Int
  sentenceText String
  s3Key        String
  mimeType     String
  durationSecs Float?
  createdAt    DateTime @default(now())

  driver       Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("reading_recordings")
}

model Document {
  id               String                    @id @default(cuid())
  driverId         String
  type             DocumentType
  s3Key            String
  fileName         String
  mimeType         String
  uploadedAt       DateTime                  @default(now())

  driver           Driver                    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  faceVerification DocumentFaceVerification?

  @@map("documents")
}

model DocumentFaceVerification {
  id           String   @id @default(cuid())
  documentId   String   @unique
  driverId     String
  score        Float
  passed       Boolean
  livePhotoKey String
  verifiedAt   DateTime @default(now())

  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_face_verifications")
}

model Verification {
  id                  String            @id @default(cuid())
  driverId            String            @unique
  faceMatchScore      Float?
  faceMatchPassed     Boolean?
  faceMatchedAt       DateTime?
  readingTestPassed   Boolean?
  readingTestScore    Float?
  readingTestedAt     DateTime?
  overallStatus       VerificationStatus @default(PENDING)
  completedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  driver              Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  readingAttempts     ReadingAttempt[]

  @@map("verifications")
}

model ReadingAttempt {
  id               String      @id @default(cuid())
  verificationId   String
  sentenceIds      String[]
  transcription    String
  expectedText     String
  score            Float
  passed           Boolean
  attemptedAt      DateTime    @default(now())

  verification     Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@map("reading_attempts")
}

model TestSentence {
  id         String   @id @default(cuid())
  text       String
  category   String   @default("general")
  difficulty Int      @default(1)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("test_sentences")
}

enum DocumentType {
  DRIVERS_LICENSE
  PASSPORT
  GREEN_CARD
  BIRTH_CERTIFICATE
  OTHER
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  EXPIRED
}
